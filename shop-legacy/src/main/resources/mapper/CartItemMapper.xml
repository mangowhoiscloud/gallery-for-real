<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.shop.mapper.CartItemMapper">

    <resultMap id="cartItemResultMap" type="com.example.shop.domain.CartItem">
        <id     property="id"            column="id"/>
        <result property="cartId"        column="cart_id"/>
        <result property="productId"     column="product_id"/>
        <result property="quantity"      column="quantity"/>
        <result property="createdAt"     column="created_at"/>
        <result property="productName"   column="product_name"/>
        <result property="unitPrice"     column="unit_price"/>
        <result property="productStatus" column="product_status"/>
    </resultMap>

    <insert id="insert" parameterType="com.example.shop.domain.CartItem"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO cart_items (cart_id, product_id, quantity)
        VALUES (#{cartId}, #{productId}, #{quantity})
    </insert>

    <select id="selectByCartId" parameterType="long" resultMap="cartItemResultMap">
        SELECT ci.id,
               ci.cart_id,
               ci.product_id,
               ci.quantity,
               ci.created_at,
               p.name    AS product_name,
               p.price   AS unit_price,
               p.status  AS product_status
        FROM cart_items ci
        JOIN products p ON p.id = ci.product_id
        WHERE ci.cart_id = #{cartId}
        ORDER BY ci.id
    </select>

    <select id="selectById" parameterType="long" resultMap="cartItemResultMap">
        SELECT ci.id,
               ci.cart_id,
               ci.product_id,
               ci.quantity,
               ci.created_at,
               p.name    AS product_name,
               p.price   AS unit_price,
               p.status  AS product_status
        FROM cart_items ci
        JOIN products p ON p.id = ci.product_id
        WHERE ci.id = #{id}
    </select>

    <update id="updateQuantity" parameterType="map">
        UPDATE cart_items
        SET quantity = #{quantity}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM cart_items WHERE id = #{id}
    </delete>

    <delete id="deleteByCartId" parameterType="long">
        DELETE FROM cart_items WHERE cart_id = #{cartId}
    </delete>

    <select id="countByCartId" parameterType="long" resultType="int">
        SELECT COUNT(*) FROM cart_items WHERE cart_id = #{cartId}
    </select>

</mapper>
